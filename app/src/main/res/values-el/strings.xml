    <!-- Exercise Explanations -->
    <string name="ex_name_desc">Το κοινό όνομα της άσκησης (π.χ. "Πιέσεις Πάγκου"). Με αυτό το όνομα θα την αναζητάτε όταν δημιουργείτε προγράμματα προπόνησης.</string>
    <string name="ex_muscle_group_desc">Η κύρια μυϊκή ομάδα που στοχεύει αυτή η άσκηση. Σας βοηθά να φιλτράρετε και να ισορροπείτε τα προγράμματά σας.</string>
    <string name="ex_equipment_desc">Τα εργαλεία που απαιτούνται για την άσκηση (π.χ. "Αλτήρες", "Μπάρα" ή "Κανένα" για ασκήσεις σωματικού βάρους).</string>
    <string name="ex_difficulty_desc">Πόσο απαιτητική είναι η άσκηση. Χρήσιμο για την επιλογή κατάλληλων ασκήσεων ανάλογα με το επίπεδο του πελάτη.</string>
    <string name="ex_instructions_desc">Οδηγίες βήμα προς βήμα για το πώς να εκτελέσετε την άσκηση με ασφάλεια και αποτελεσματικότητα.</string>
    <string name="ex_focus_area_desc">Η γενική περιοχή του σώματος που στοχεύεται (Άνω, Κάτω ή Όλο το Σώμα).</string>
    <string name="ex_training_type_desc">Η φύση της άσκησης: Αντίσταση (δύναμη), Καρδιοαναπνευστική (αντοχή) ή Κινητικότητα (ευλυγισία).</string>
    <string name="ex_image_res_desc">Το όνομα ενός εσωτερικού αρχείου εικόνας της εφαρμογής που σχετίζεται με αυτήν την άσκηση (τεχνικό πεδίο).</string>
    <string name="ex_video_res_desc">Το όνομα ενός εσωτερικού αρχείου βίντεο της εφαρμογής που σχετίζεται με αυτήν την άσκηση (τεχνικό πεδίο).</string>
    <string name="ex_external_media_desc">Ανεβάστε δικές σας εικόνες ή βίντεο από τη συσκευή σας για να δείξετε οπτικά την άσκηση στους πελάτες σας.</string>

    <string name="add_subscription_plan">Προσθήκη Προγράμματος Συνδρομής</string>
    <string name="save_plan">Αποθήκευση Προγράμματος</string>
    <string name="plan_name_hint">π.χ. Μηνιαίο Silver</string>
    <string name="plan_name_desc">Το όνομα του πακέτου συνδρομής. Αυτό θα βλέπετε εσείς και οι πελάτες σας κατά την επιλογή προγράμματος.</string>
    <string name="plan_price_desc">Το κόστος του προγράμματος. Αυτό το ποσό θα προτείνεται αυτόματα όταν δημιουργείτε μια νέα συνδρομή για έναν πελάτη.</string>
    <string name="plan_duration_type_desc">Επιλέξτε τη μονάδα μέτρησης χρόνου. Η μηνιαία επιλογή είναι ιδανική για σταθερά προγράμματα, ενώ οι ημέρες επιτρέπουν ειδικές διάρκειες (π.χ. πάσο 10 ημερών).</string>
    <string name="plan_duration_value_desc">Η πραγματική διάρκεια του προγράμματος. Για παράδειγμα, αν επιλέξατε "Μηνιαίο", βάλτε "1" για έναν μήνα. Αυτό ορίζει την ημερομηνία της επόμενης πληρωμής.</string>
    <string name="plan_description_desc">Προαιρετικές λεπτομέρειες για τις παροχές (π.χ. "Περιλαμβάνει χρήση σάουνας"). Σας βοηθά να ξεχωρίζετε παρόμοια προγράμματα.</string>
    <string name="add_plan_info">Εδώ δημιουργείτε τα πακέτα συνδρομών σας. Ορίστε το όνομα, την τιμή και τη διάρκεια. Αυτά τα πλάνα θα εμφανίζονται ως επιλογές όταν προσθέτετε μια νέα συνδρομή σε έναν πελάτη.</string>
    <string name="error_name_required">Το όνομα είναι υποχρεωτικό</string>
    <string name="error_mg_required">Η μυϊκή ομάδα είναι υποχρεωτική</string>

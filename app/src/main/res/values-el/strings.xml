    <!-- Workout Plan Explanations -->
    <string name="wp_name_desc">Δώστε ένα περιγραφικό όνομα στο πρόγραμμα (π.χ. "Δύναμη Άνω Μέρους" ή "Καρδιοαναπνευστική Παρασκευής"). Αυτό το όνομα θα εμφανίζεται όταν συνδέετε ένα πρόγραμμα με μια συνεδρία.</string>
    <string name="wp_notes_desc">Προαιρετικές σημειώσεις ή οδηγίες για το συνολικό πρόγραμμα. Αυτές θα μπορούσαν να περιλαμβάνουν συμβουλές προθέρμανσης ή το επιδιωκόμενο επίπεδο έντασης.</string>
    <string name="wp_exercises_desc">Μια λίστα με τις ασκήσεις που απαρτίζουν αυτή την προπόνηση. Μπορείτε να προσθέσετε, να αφαιρέσετε και να ρυθμίσετε σετ, επαναλήψεις και ξεκούραση για την καθεμία.</string>
    <string name="wp_add_ex_desc">Αναζητήστε μια άσκηση από τη βιβλιοθήκη σας και ορίστε τις παραμέτρους της, όπως σετ, επαναλήψεις ή διάρκεια για αυτό το συγκεκριμένο πρόγραμμα.</string>
    <string name="wp_ex_type_desc">Επιλέξτε "Επαναλήψεις" για ασκήσεις που βασίζονται σε επαναλήψεις (όπως push-ups) ή "Χρόνο" για ασκήσεις που βασίζονται στη διάρκεια (όπως σανίδα).</string>
    <string name="wp_timer_type_desc">Για ασκήσεις βάσει χρόνου, επιλέξτε "Αντίστροφη μέτρηση" για να βλέπετε τον υπολειπόμενο χρόνο ή "Κανονική μέτρηση" για να βλέπετε τον χρόνο που πέρασε.</string>
    <string name="wp_sets_desc">Ο αριθμός των φορών που θα εκτελέσετε την άσκηση. Στις ασκήσεις βάσει χρόνου, αυτό συχνά ονομάζεται "Γύροι".</string>
    <string name="wp_reps_val_desc">Ο αριθμός των επαναλήψεων ανά σετ. Αφήστε το στο 0 εάν πρόκειται για άσκηση βάσει χρόνου.</string>
    <string name="wp_duration_desc">Ο στόχος χρόνου σε δευτερόλεπτα για κάθε σετ ή γύρο μιας άσκησης βάσει χρόνου.</string>
    <string name="wp_rest_desc">Ο χρόνος ανάπαυσης σε δευτερόλεπτα μεταξύ κάθε σετ ή γύρου. Η αποκατάσταση είναι το κλειδί για τη διατήρηση της απόδοσης!</string>


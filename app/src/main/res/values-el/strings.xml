    <!-- Training Session Explanations -->
    <string name="ts_client_desc">Επιλέξτε τον πελάτη για τον οποίο προορίζεται αυτή η συνεδρία. Αυτό συνδέει την προπόνηση με το προφίλ του.</string>
    <string name="ts_date_desc">Η ημέρα κατά την οποία έχει προγραμματιστεί να πραγματοποιηθεί η συνεδρία προπόνησης.</string>
    <string name="ts_time_desc">Η ακριβής ώρα έναρξης της συνεδρίας προπόνησης.</string>
    <string name="ts_duration_desc">Η προγραμματισμένη διάρκεια της συνεδρίας σε λεπτά. Αυτό σας βοηθά να διαχειριστείτε το καθημερινό σας πρόγραμμα.</string>
    <string name="ts_type_desc">Η κύρια εστίαση ή κατηγορία της συνεδρίας (π.χ. "Πόδια", "Λειτουργική Προπόνηση").</string>
    <string name="ts_plan_desc">Προαιρετικά συνδέστε ένα έτοιμο πρόγραμμα προπόνησης. Αυτό επιτρέπει την παρακολούθηση των ασκήσεων βήμα προς βήμα κατά τη διάρκεια της συνεδρίας.</string>
    <string name="ts_status_desc">Τρέχουσα κατάσταση: Προγραμματισμένη (επικείμενη), Ολοκληρωμένη ή Ακυρωμένη.</string>
    <string name="ts_notes_desc">Τυχόν ειδικές οδηγίες, αιτήματα πελατών ή υπενθυμίσεις για τη συγκεκριμένη συνεδρία.</string>

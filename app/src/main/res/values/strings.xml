    <!-- Workout Plan Explanations -->
    <string name="wp_name_desc">Give your workout plan a descriptive name (e.g., \"Upper Body Power\" or \"Friday Cardio\"). This name will appear when you link a plan to a training session.</string>
    <string name="wp_notes_desc">Optional notes or instructions for the overall plan. These could include general warm-up tips or the intended intensity level.</string>
    <string name="wp_exercises_desc">A list of exercises that make up this workout. You can add, remove, and configure sets, reps, and rest for each one.</string>
    <string name="wp_add_ex_desc">Search for an exercise from your library and define its parameters like sets, reps, or duration for this specific plan.</string>
    <string name="wp_ex_type_desc">Choose \"Reps\" for exercises based on repetitions (like push-ups) or \"Time\" for duration-based exercises (like planks).</string>
    <string name="wp_timer_type_desc">For time-based exercises, choose \"Count-down\" to see remaining time or \"Count-up\" to see elapsed time during the workout.</string>
    <string name="wp_sets_desc">The number of times you will perform the exercise. In time-based exercises, this is often called \"Rounds\".</string>
    <string name="wp_reps_val_desc">The number of repetitions per set. Leave at 0 if this is a time-based exercise.</string>
    <string name="wp_duration_desc">The target time in seconds for each set or round of a time-based exercise.</string>
    <string name="wp_rest_desc">The rest time in seconds between each set or round. Recovery is key for maintaining performance!</string>


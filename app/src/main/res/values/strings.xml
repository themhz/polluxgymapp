    <!-- Exercise Explanations -->
    <string name="ex_name_desc">The common name of the exercise (e.g., \"Bench Press\"). This is what you\'ll search for when building workout plans.</string>
    <string name="ex_muscle_group_desc">The primary muscle targeted by this exercise. This helps you filter and balance your workout plans.</string>
    <string name="ex_equipment_desc">The tools required for the exercise (e.g., \"Dumbbells\", \"Barbell\", or \"None\" for bodyweight).</string>
    <string name="ex_difficulty_desc">How challenging the exercise is. Useful for selecting appropriate exercises based on a client\'s fitness level.</string>
    <string name="ex_instructions_desc">Step-by-step guide on how to perform the exercise safely and effectively.</string>
    <string name="ex_focus_area_desc">The general body region targeted (Upper, Lower, or Full Body).</string>
    <string name="ex_training_type_desc">The nature of the exercise: Resistance (strength), Cardio (endurance), or Mobility (flexibility).</string>
    <string name="ex_image_res_desc">The name of an internal app image file associated with this exercise (technical field).</string>
    <string name="ex_video_res_desc">The name of an internal app video file associated with this exercise (technical field).</string>
    <string name="ex_external_media_desc">Upload your own images or videos from your device to visually demonstrate the exercise to your clients.</string>

